# =============================================
# MyPharm - Regras de Segurança (.htaccess)
# =============================================

# ----- Proteger .env (credenciais) -----
<FilesMatch "^\.env$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# ----- Proteger config.php (acesso direto) -----
<FilesMatch "^config\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# ----- Bloquear acesso a arquivos sensíveis (.bak, .log, .sql, .sh, .git) -----
<FilesMatch "\.(bak|log|sql|sh|ini|conf|dist|orig|save|swp)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# ----- Desabilitar listagem de diretórios -----
Options -Indexes

# ----- Proteger pastas sensíveis (Dados, scripts) -----
<IfModule mod_rewrite.c>
    RewriteEngine On
    # TV: JS em cache ou legado pede /assets/sounds/*.mp3 — servir desde tv/public/audio/
    # Funciona na raiz (Hostinger) e com prefixo /mypharm/ (XAMPP).
    RewriteRule ^(.*/)?assets/sounds/ranking-update\.mp3$ $1tv/public/audio/passagem.mp3 [L]
    RewriteRule ^(.*/)?assets/sounds/rank-up\.mp3$ $1tv/public/audio/pedido.mp3 [L]
    RewriteRule ^(.*/)?assets/sounds/top3-enter\.mp3$ $1tv/public/audio/aplausos.mp3 [L]
    RewriteRule ^(.*/)?assets/sounds/meta-hit\.mp3$ $1tv/public/audio/aplausos.mp3 [L]
    RewriteRule ^(.*/)?assets/sounds/warning\.mp3$ $1tv/public/audio/passagem.mp3 [L]
    RewriteRule ^(.*/)?assets/sounds/click-soft\.mp3$ $1tv/public/audio/clicarusuario.mp3 [L]
    RewriteRule ^Dados/ - [F,L]
    RewriteRule ^scripts/importar_itens_cli\.php - [F,L]
</IfModule>

# ----- Headers de segurança para páginas HTML -----
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    # SAMEORIGIN: permite embed na mesma origem (ex.: gestao-comercial no index); DENY bloqueava iframe mesmo local.
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(self), camera=(), microphone=()"

    # Todas as paginas HTML: sem cache agressivo (producao parecia "nunca atualizar" apos deploy)
    <FilesMatch "\.(html|htm)$">
        Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://unpkg.com; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://unpkg.com https://fonts.googleapis.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; img-src 'self' data: https://*.tile.openstreetmap.org https://*.basemaps.cartocdn.com https://unpkg.com https://i.pravatar.cc https://www.gravatar.com https://secure.gravatar.com https://ui-avatars.com; connect-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://unpkg.com https://viacep.com.br https://servicodados.ibge.gov.br https://nominatim.openstreetmap.org;"
        Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header unset ETag
    </FilesMatch>
</IfModule>

# ----- Prevenir acesso a arquivos ocultos (.git, .env, etc) -----
<IfModule mod_rewrite.c>
    RewriteRule (^\.|/\.) - [F,L]
</IfModule>

# ----- Limitar métodos HTTP permitidos (OPTIONS permitido para CORS preflight) -----
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_METHOD} !^(GET|POST|HEAD|OPTIONS) [NC]
    RewriteRule .* - [F,L]
</IfModule>
