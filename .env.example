# =============================================
# Configuração do Banco de Dados - MyPharm
# =============================================
# Copie este arquivo para .env e preencha com suas credenciais

DB_HOST=seu_host_aqui
DB_NAME=seu_banco_aqui
DB_USER=seu_usuario_aqui
DB_PASS=sua_senha_aqui
DB_CHARSET=utf8mb4

# RD Station CRM (opcional) — TV e gestão comercial
# RDSTATION_CRM_TOKEN=

# Cache da TV Corrida (produção / Hostinger)
# RD_TV_CACHE_DIR=/caminho/absoluto/gravavel
# RD_TV_CACHE_TTL=90
# Idade máxima (s) do snapshot RD após falha da API; depois usa ranking MySQL
# RD_TV_STALE_MAX_SEC=900
